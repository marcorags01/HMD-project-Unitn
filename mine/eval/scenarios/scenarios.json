[
  {
    "id": "happy_path_confirm",
    "description": "Plan -> menus -> select menu -> inspect day -> confirm shopping list",
    "turns": [
      {
        "mrs": [
          {"intent": "plan", "slots": {"servings": 2, "time_limit": "FAST", "calorie_level": "MED", "avoid_items": ["nuts"]}}
        ]
      },
      {
        "mrs": [
          {"intent": "select_menu", "slots": {"menu_id": 1}}
        ]
      },
      {
        "mrs": [
          {"intent": "inspect", "slots": {"target_day": "Tue"}}
        ]
      },
      {
        "mrs": [
          {"intent": "confirm", "slots": {}}
        ]
      }
    ],
    "expect": {"phase": "CONFIRMED", "has_active_menu": true}
  },
  {
    "id": "multi_intent_deferral_continue",
    "description": "After active menu, user asks inspect and avoid update in same turn; refine deferred and confirmed via yes.",
    "turns": [
      {
        "mrs": [
          {"intent": "plan", "slots": {"servings": 2, "time_limit": "NORMAL", "calorie_level": "MED", "avoid_items": []}}
        ]
      },
      {"mrs": [{"intent": "select_menu", "slots": {"menu_id": 1}}]},
      {
        "mrs": [
          {"intent": "inspect", "slots": {"target_day": "Wed"}},
          {"intent": "refine", "slots": {"refine_type": "ADD_AVOID_ITEM", "value": "egg"}}
        ]
      },
      {
        "user_text": "yes"
      }
    ],
    "expect": {"phase": "ACTIVE_MENU", "has_active_menu": true}
  }
]

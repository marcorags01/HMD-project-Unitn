[
  {
    "id": "scn_slotfill_happy_path",
    "description": "Slot-filling plan -> propose menus -> select menu -> show a day -> confirm.",
    "initial_state": {
      "phase": "AWAITING_PLAN",
      "constraints": {"servings": null, "time_limit": null, "calorie_level": null, "avoid_items": null}
    },
    "turns": [
      {
        "user_text": "Plan meals for 2 people.",
        "mrs": [{"intent": "plan", "slots": {"servings": 2}}]
      },
      {
        "user_text": "quick",
        "mrs": [{"intent": "plan", "slots": {"time_limit": "FAST"}}]
      },
      {
        "user_text": "balanced",
        "mrs": [{"intent": "plan", "slots": {"calorie_level": "MED"}}]
      },
      {
        "user_text": "No allergies.",
        "mrs": [{"intent": "plan", "slots": {"avoid_items": []}}]
      },
      {
        "user_text": "Option 1.",
        "mrs": [{"intent": "select_menu", "slots": {"menu_id": 1}}]
      },
      {
        "user_text": "What's planned for Tue?",
        "mrs": [{"intent": "inspect", "slots": {"target_day": "Tue"}}]
      },
      {
        "user_text": "Finalize and generate the shopping list.",
        "mrs": [{"intent": "confirm", "slots": {}}]
      }
    ],
    "expected": {
      "final_phase": "CONFIRMED",
      "must_have_active_menu": true,
      "constraints_complete": true
    }
  },

